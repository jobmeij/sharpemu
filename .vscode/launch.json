{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug SharpEmu.CLI",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/artifacts/bin/Debug/net10.0/win-x64/SharpEmu.dll",
      "cwd": "${workspaceFolder}/artifacts/bin/Debug/net10.0/win-x64",
      "console": "integratedTerminal",
      "stopAtEntry": false,
      "justMyCode": false,
      "env": {
        "SHARPEMU_DIRECT_MEMORY": "1"
      }
    }
  ]
}